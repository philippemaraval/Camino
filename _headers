# Service worker: always fetch latest, never long-cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# Daily image files: cache 1 week and keep image MIME types correct
/data/daily_images/*.jpg
  Cache-Control: public, max-age=604800, immutable
  Content-Type: image/jpeg

/data/daily_images/*.jpeg
  Cache-Control: public, max-age=604800, immutable
  Content-Type: image/jpeg

/data/daily_images/*.webp
  Cache-Control: public, max-age=604800, immutable
  Content-Type: image/webp

# Data files: cache 1 week (data changes via OSM sync + redeploy)
/data/*.json
  Cache-Control: public, max-age=604800, immutable
  Content-Type: application/json; charset=utf-8

/data/*.geojson
  Cache-Control: public, max-age=604800, immutable
  Content-Type: application/geo+json; charset=utf-8

# CSS/JS: cache long, URLs versionnees dans index.html
/*.css
  Cache-Control: public, max-age=604800, immutable

/*.js
  Cache-Control: public, max-age=604800, immutable

# HTML: NO cache
/*.html
  Cache-Control: no-cache, must-revalidate
/
  Cache-Control: no-cache, must-revalidate
